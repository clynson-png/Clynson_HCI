{
  "schemaVersion": "1.0.0",
  "assetName": "hci_happy_prescription_canonical",
  "createdAt": "2026-06-24",
  "language": "en-US",
  "purpose": "Canonical prescription matrix for the HAPPY Engine. It connects HAPPY/COMANDO gaps to the HAPPY exercise library and cross-validates prescription using HCI performance evidence.",
  "sourceLibrary": "hci_happy_library_canonical.json",
  "enginePrinciple": "The engine prescribes by GAP, not by absolute score. Lowest dimension -> critical parameter -> cross-evidence -> exercise prescription -> reassessment.",
  "severityBands": {
    "CRITICAL": {
      "range": "< 2.0",
      "meaning": "Immediate development priority"
    },
    "ATTENTION": {
      "range": "2.0 - 2.99",
      "meaning": "Needs focused intervention"
    },
    "STABLE": {
      "range": "3.0 - 3.99",
      "meaning": "Monitor and consolidate"
    },
    "HIGH_PERFORMANCE": {
      "range": "4.0 - 4.49",
      "meaning": "Maintain and refine"
    },
    "ELITE": {
      "range": "4.5 - 5.0",
      "meaning": "Reference behavior"
    }
  },
  "selectionFlow": [
    "Calculate 5 HAPPY dimensions from subjective indicators.",
    "Identify the lowest dimension and Top 3 dimensional gaps.",
    "Open the lowest dimension and identify the parameter with the largest negative contribution.",
    "Cross-check the parameter with HCI evidence: TARGETS, STRUCTURE, RHYTHM, RESULT.",
    "Classify severity.",
    "Select exercises from hci_happy_library_canonical.json.",
    "Generate coach prescription and athlete-safe development plan.",
    "Reassess after the prescribed block."
  ],
  "rules": [
    {
      "ruleId": "HAPPY_RX_CONFIDENCE_GAP",
      "parameter": "CONFIDENCE",
      "trigger": {
        "condition": "parameter is the lowest contributor inside the lowest HAPPY dimension OR appears in Top 3 gaps",
        "criticalIf": "score < 2.0",
        "attentionIf": "2.0 <= score < 3.0",
        "monitorIf": "3.0 <= score < 4.0"
      },
      "hciCrossEvidence": {
        "primaryHciEvidence": "OUTCOME",
        "secondaryHciEvidence": [
          "CONSISTENCY",
          "PRESSURE"
        ],
        "reading": "Confidence is real when it is supported by score, repetition, and pressure stability."
      },
      "prescriptionLogic": {
        "critical": {
          "dosage": "3 exercises / 2 weeks / coach follow-up required",
          "exerciseIds": [
            "HAPPY_CONFIDENCE_001",
            "HAPPY_CONFIDENCE_002",
            "HAPPY_CONFIDENCE_003"
          ],
          "coachAction": "Create a short intervention block and reassess after 2 weeks."
        },
        "attention": {
          "dosage": "2 exercises / 2 weeks / athlete report + coach review",
          "exerciseIds": [
            "HAPPY_CONFIDENCE_001",
            "HAPPY_CONFIDENCE_002"
          ],
          "coachAction": "Assign focused exercises and verify adherence."
        },
        "monitor": {
          "dosage": "1 exercise / 1 week / self-report",
          "exerciseIds": [
            "HAPPY_CONFIDENCE_001"
          ],
          "coachAction": "Monitor trend and prevent regression."
        }
      },
      "athleteOutput": {
        "tone": "developmental, non-judgmental, action-oriented",
        "label": "Current development focus: Confidence"
      }
    },
